generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

enum CustomerStatus {
  active
  prospect
  inactive
}

enum EmploymentType {
  full_time
  part_time
  contractor
}

enum ProjectStatus {
  planning
  active
  on_hold
  completed
  cancelled
}

enum BillingType {
  fixed_price
  time_and_materials
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  passwordHash String  @map("password_hash")
  role       Role      @default(VIEWER)
  employeeId String?   @unique @map("employee_id")
  employee   Employee? @relation(fields: [employeeId], references: [id])
  isActive   Boolean   @default(true) @map("is_active")
  isRestricted Boolean @default(false) @map("is_restricted")
  projectAccess ProjectAccess[]
  passwordTokens PasswordSetToken[]
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

// One-time, expiring tokens for account invites ("set your password") and
// self-service password resets. Only the SHA-256 hash of the token is stored;
// the raw token lives only in the emailed link.
model PasswordSetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  purpose   String    // 'invite' | 'reset'
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_set_tokens")
}

model ProjectAccess {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("project_access")
}

model Customer {
  id                  String         @id @default(uuid())
  name                String
  contactName         String?        @map("contact_name")
  contactEmail        String?        @map("contact_email")
  status              CustomerStatus @default(prospect)
  notes               String?
  hasLicense          Boolean        @default(false) @map("has_license")
  licenseAnnualAmount Decimal?       @map("license_annual_amount") @db.Decimal(14, 2)
  licensePeriodStart  DateTime?      @map("license_period_start") @db.Date
  licensePeriodEnd    DateTime?      @map("license_period_end") @db.Date
  licensePaid         Boolean        @default(false) @map("license_paid")
  licensePlatformVersion String?     @map("license_platform_version")
  licenseModelsInstalled String[]    @default([]) @map("license_models_installed")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  projects Project[]
  timeImportBatches TimeImportBatch[]

  @@index([status])
  @@map("customers")
}

model Employee {
  id                   String         @id @default(uuid())
  firstName            String         @map("first_name")
  lastName             String         @map("last_name")
  email                String         @unique
  title                String?
  department           String?
  employmentType       EmploymentType @default(full_time) @map("employment_type")
  monthlyCapacityHours Decimal        @default(186) @map("monthly_capacity_hours") @db.Decimal(7, 2)
  costRateHourly       Decimal?       @map("cost_rate_hourly") @db.Decimal(10, 2)
  isActive             Boolean        @default(true) @map("is_active")
  startDate            DateTime?      @map("start_date") @db.Date
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  user               User?
  assignments        ProjectAssignment[]
  allocations        MonthlyAllocation[]
  capacityOverrides  CapacityOverride[]
  timeActuals        TimeEntryActual[]

  @@index([department])
  @@index([isActive])
  @@map("employees")
}

model Project {
  id            String        @id @default(uuid())
  customerId    String        @map("customer_id")
  customer      Customer      @relation(fields: [customerId], references: [id])
  name          String
  code          String        @unique
  status        ProjectStatus @default(planning)
  startDate     DateTime?     @map("start_date") @db.Date
  endDate       DateTime?     @map("end_date") @db.Date
  incomeAmount  Decimal       @default(0) @map("income_amount") @db.Decimal(14, 2)
  hoursPaid     Decimal       @default(0) @map("hours_paid") @db.Decimal(10, 2)
  currency      String        @default("ILS")
  billingType   BillingType   @default(time_and_materials) @map("billing_type")
  description   String?
  githubRepoUrl String?       @map("github_repo_url")
  jiraBoardUrl  String?       @map("jira_board_url")
  poFileName    String?       @map("po_file_name")
  poStoredName  String?       @map("po_stored_name")
  poMimeType    String?       @map("po_mime_type")
  poFileSize    Int?          @map("po_file_size")
  poUploadedAt  DateTime?     @map("po_uploaded_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  assignments ProjectAssignment[]
  allocations MonthlyAllocation[]
  accessGrants ProjectAccess[]
  timeActuals TimeEntryActual[]

  @@index([customerId])
  @@index([status])
  @@map("projects")
}

model ProjectAssignment {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId    String   @map("employee_id")
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  roleOnProject String?  @map("role_on_project")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([projectId, employeeId])
  @@map("project_assignments")
}

model MonthlyAllocation {
  id            String    @id @default(uuid())
  employeeId    String    @map("employee_id")
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId     String    @map("project_id")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  month         DateTime  @db.Date
  plannedHours  Decimal   @default(0) @map("planned_hours") @db.Decimal(7, 2)
  actualHours   Decimal?  @map("actual_hours") @db.Decimal(7, 2)
  note          String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([employeeId, projectId, month])
  @@index([month, employeeId])
  @@index([projectId, month])
  @@map("monthly_allocations")
}

model CapacityOverride {
  id             String   @id @default(uuid())
  employeeId     String   @map("employee_id")
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month          DateTime @db.Date
  capacityHours  Decimal  @map("capacity_hours") @db.Decimal(7, 2)
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([employeeId, month])
  @@map("capacity_overrides")
}

model AppSettings {
  id                     Int    @id @default(1)
  defaultCurrency        String @default("ILS") @map("default_currency")
  planningWindowMonths   Int    @default(6) @map("planning_window_months")
  defaultCapacityHours   Decimal @default(186) @map("default_capacity_hours") @db.Decimal(7, 2)

  @@map("app_settings")
}

// A single uploaded customer-hours (attendance) file. Holds the parsed,
// aggregated preview until an admin reconciles unmatched names and commits it.
model TimeImportBatch {
  id                 String    @id @default(uuid())
  originalFileName   String    @map("original_file_name")
  sourceCustomerName String?   @map("source_customer_name")
  customerId         String?   @map("customer_id")
  customer           Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  periodStart        DateTime  @map("period_start") @db.Date
  periodEnd          DateTime  @map("period_end") @db.Date
  totalHours         Decimal   @map("total_hours") @db.Decimal(10, 2)
  entryCount         Int       @map("entry_count")
  status             String    @default("pending_review") // pending_review | committed
  lines              Json      // parsed + aggregated preview lines (source names + matched ids)
  uploadedById       String?   @map("uploaded_by_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  committedAt        DateTime? @map("committed_at")

  actuals TimeEntryActual[]

  @@index([customerId])
  @@index([status])
  @@map("time_import_batches")
}

// Committed actual hours, kept at the sub-project grain for drill-down.
// Rolled up into MonthlyAllocation.actualHours per (employee, project, month).
model TimeEntryActual {
  id         String   @id @default(uuid())
  batchId    String   @map("batch_id")
  batch      TimeImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  projectId  String   @map("project_id")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId String   @map("employee_id")
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month      DateTime @db.Date
  subProject String?  @map("sub_project")
  hours      Decimal  @db.Decimal(8, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([projectId, month])
  @@index([employeeId, month])
  @@index([batchId])
  @@map("time_entry_actuals")
}

// Learned mapping from a source name in an attendance file to an app record,
// so future uploads of the same name match automatically. kind: employee|project|customer.
model ImportAlias {
  id         String   @id @default(uuid())
  kind       String
  sourceName String   @map("source_name")
  targetId   String   @map("target_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([kind, sourceName])
  @@map("import_aliases")
}

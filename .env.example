DATABASE_URL=postgresql://USER:PASS@localhost:5432/jeen_planner
JWT_SECRET=change_me
PORT=4000
NODE_ENV=production
DEFAULT_CURRENCY=ILS
PLANNING_WINDOW_MONTHS=6
DEFAULT_MONTHLY_CAPACITY_HOURS=186

# Admin bootstrap account (created by prisma/seed.ts)
ADMIN_EMAIL=admin@jeen.ai
ADMIN_PASSWORD=change_me

# Set to "true" to also insert sample customers/employees/projects when
# running prisma/seed.ts. Leave unset in production — the admin user and
# app settings always seed regardless of this flag.
SEED_DEMO_DATA=false

# Public URL of the web app, used in emails (e.g. the welcome email login link).
APP_BASE_URL=http://localhost:5173

# SMTP config for outgoing email (welcome email button in Settings).
# Leave SMTP_HOST/SMTP_USER/SMTP_PASS unset to disable email sending (the
# button then shows a clear "email not configured" error instead of failing).
#
# Works with any SMTP provider. Example below is SendGrid using a verified
# single sender (no domain DNS required — you verify one From address by
# clicking a link emailed to it). For SendGrid, SMTP_USER is the literal word
# "apikey" and SMTP_PASS is the API key. MAIL_FROM must EXACTLY match the
# verified sender address.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=SG.your_api_key_here
MAIL_FROM="Jeen Solution OS <eran@jeen.ai>"

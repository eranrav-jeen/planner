server {
    listen 80;
    server_name planner.raviv360.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name planner.raviv360.com;

    ssl_certificate     /etc/letsencrypt/live/planner.raviv360.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/planner.raviv360.com/privkey.pem;

    root /var/www/jeen-project-planner/apps/web/dist;
    index index.html;

    location /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri /index.html;
    }

    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;
}
